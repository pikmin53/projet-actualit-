# --- Base de données ---
# PostgreSQL partout. Avec docker compose, le service "db" est exposé sur localhost:5432 :
DATABASE_URL="postgresql://globeactu:globeactu@localhost:5432/globeactu"
# En prod cloud (Vercel + cron GitHub Actions) : une URL Postgres managée (Supabase/Neon), ex:
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Mot de passe du Postgres lancé par docker compose (défaut : globeactu).
POSTGRES_PASSWORD="globeactu"

# Intervalle (secondes) entre deux passes d'ingestion du service docker "ingest".
INGEST_INTERVAL_SECONDS="1200"

# --- Sources de données externes ---
# Optionnel : clé d'une API d'actualité gratuite (NewsAPI ou GNews) pour enrichir les flux RSS.
# Sans clé, l'ingestion fonctionne avec les flux RSS + Google News RSS + GDELT (tous sans clé).
NEWSAPI_KEY=""
GNEWS_KEY=""

# --- Pipeline NLP (providers interchangeables, voir docs/strategie/resume-et-interpretation.md) ---
# Valeurs possibles pour SUMMARIZER_PROVIDER : "extractive" (défaut, local, sans dépendance ML) | "transformers-distilbart" (local, plus lourd)
SUMMARIZER_PROVIDER="extractive"
# Valeurs possibles pour INTERPRETER_PROVIDER : "heuristic" (défaut, local, sans coût)
INTERPRETER_PROVIDER="heuristic"

# --- API publique /api/v1/* ---
# Optionnel : si défini, les routes exigent le header "x-api-key" avec cette valeur.
# Laisser vide en développement pour garder l'API ouverte.
PUBLIC_API_KEY=""
# Origines autorisées en CORS, séparées par des virgules. "*" autorise toute origine (pratique en dev).
ALLOWED_ORIGINS="*"
