{
  "name": "globe-actu",
  "version": "0.1.0",
  "private": true,
  "description": "Visualisation en direct de l'actualité mondiale sur un globe 3D animé.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "ingest": "tsx scripts/ingest.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "dotenv": "^16.4.5",
    "next": "^16.2.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-globe.gl": "^2.38.0",
    "recharts": "^3.9.2",
    "rss-parser": "^3.13.0"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "allowScripts": {
    "@prisma/client": true,
    "@prisma/engines": true,
    "prisma": true,
    "esbuild": true,
    "unrs-resolver": true
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5.10",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
