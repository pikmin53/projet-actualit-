// Schéma de données de Globe Actu.
// Voir docs/fonctions.md pour le détail des champs calculés (popularité, catégorie, etc.)
// et docs/strategie/ pour la justification de chaque heuristique.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // PostgreSQL partout : en local via docker compose (service "db"), en prod via une base
  // managée (Neon/Supabase). Voir .env.example et docker-compose.yml.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Un média/flux RSS source d'articles.
model Source {
  id        String    @id @default(cuid())
  name      String
  homepage  String
  rssUrl    String    @unique
  country   String // code pays ISO 3166-1 alpha-2 d'origine de la rédaction, ex: "FR", "US"
  language  String // code langue ISO 639-1, ex: "fr", "en"
  custom    Boolean   @default(false) // vrai si ajoutée par l'utilisateur via /parametres (POST /api/v1/sources), et non par data/sources/*.json
  enabled   Boolean   @default(true) // une source custom désactivée est conservée (ses articles restent) mais n'est plus interrogée à l'ingestion
  createdAt DateTime  @default(now())
  articles  Article[]
}

/// Un article normalisé, géolocalisé et catégorisé par le pipeline d'ingestion.
model Article {
  id              String        @id @default(cuid())
  sourceId        String
  source          Source        @relation(fields: [sourceId], references: [id])
  title           String
  url             String        @unique
  rawContent      String // texte brut récupéré du flux (titre + description), utilisé par le pipeline NLP
  summary         String // résumé produit par le SummarizerProvider actif
  category        String // "environnement" | "technologie" | "politique" | "economique" | "cybersecurite" | "science" | "autre"
  countryCode     String? // pays détecté par la géolocalisation heuristique
  locationLabel   String? // libellé humain du lieu détecté, ex: "Paris, France"
  lat             Float?
  lng             Float?
  popularityScore Float         @default(0) // voir docs/strategie/popularite.md
  publishedAt     DateTime
  createdAt       DateTime      @default(now())
  eventClusterId  String?
  eventCluster    EventCluster? @relation(fields: [eventClusterId], references: [id])

  @@index([category])
  @@index([publishedAt])
  @@index([eventClusterId])
}

/// Un regroupement d'articles (sources différentes) parlant du même évènement.
/// Porte l'interprétation neutre générée par l'InterpreterProvider actif.
model EventCluster {
  id                String    @id @default(cuid())
  label             String // titre représentatif du cluster (titre de l'article le plus ancien du groupe)
  category          String
  interpretationRaw String // JSON sérialisé : { commonPoints, divergences, dominantKeywordsBySource, impactNote, generatedBy }
  breaking          Boolean   @default(false) // vrai si la vélocité dépasse le seuil "breaking", voir src/lib/nlp/breaking.ts
  sourceVelocity    Float     @default(0) // sources distinctes ayant publié dans la fenêtre de vélocité récente
  socialConfirmations Int     @default(0) // signaux sociaux (Reddit...) rattachés à ce cluster, voir SocialSignal
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  articles          Article[]
}

/// Signal social (couche 3, voir docs/strategie/extension-sources.md) : un post Reddit/Bluesky
/// détecté. Jamais publié tel quel — c'est un "évènement candidat" qui doit être confirmé par
/// la presse (rattachement à un EventCluster) avant son expiration, sinon il est purgé.
model SocialSignal {
  id                 String   @id @default(cuid())
  platform           String // "reddit" (puis "bluesky"...)
  community          String // ex: "r/worldnews"
  title              String
  url                String   @unique // permalien du post
  externalUrl        String? // URL de l'article pointé par le post, si présent
  score              Int      @default(0) // upvotes au moment du relevé
  postedAt           DateTime
  createdAt          DateTime @default(now())
  expiresAt          DateTime // au-delà : purgé s'il n'a pas été confirmé
  confirmedClusterId String? // cluster de presse qui a confirmé ce signal

  @@index([expiresAt])
  @@index([confirmedClusterId])
}
